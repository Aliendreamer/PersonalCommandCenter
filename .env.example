# Host ports published by docker-compose. Copy to .env to override.
# CORE_API_PORT must match the web client's fallback API URL (localhost:5080) so the
# browser-side System tile can reach the API.
CORE_API_PORT=5080
WEB_PORT=3000
HA_PORT=8123

# Home Assistant long-lived access token for the IoT plugin.
# One-time setup: `docker compose up -d home-assistant`, open http://localhost:8123,
# create your account, then Profile → Security → Long-lived access tokens → Create token.
# Put it here (in your real .env, which is gitignored). Without it the Devices tile degrades.
HA_TOKEN=
