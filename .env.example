# Everything is served through Traefik on http://*.pcc.localhost (only Traefik publishes :80).
# *.localhost auto-resolves to 127.0.0.1 — no /etc/hosts needed.
#   app.pcc.localhost (web) · api.pcc.localhost (core-api) · keycloak.pcc.localhost
#   ha.pcc.localhost (Home Assistant) · portainer.pcc.localhost (existing standalone)

# Postgres (session store) password.
POSTGRES_PASSWORD=pcc-dev

# Keycloak confidential client secret for `pcc_api` (matches harness/keycloak/Pcc-realm.json).
KEYCLOAK_CLIENT_SECRET=pcc-dev-secret

# --- Plugin secrets -------------------------------------------------------------------
# .NET config keys (NOT friendly names) — docker-compose injects this whole file into the
# core-api container via `env_file: .env`, and .NET binds `Plugins__<Id>__<Key>` to the
# plugin's Options. Non-secret plugin config + Enabled live in appsettings.json; container
# addresses are the plugins' Options defaults. Only put secrets/personal values here.

# Home Assistant long-lived access token (IoT/Devices tile degrades to 502 without it).
# One-time: open http://ha.pcc.localhost, Profile → Security → Long-lived access tokens.
Plugins__Iot__HomeAssistant__Token=

# Wakapi API key (Coding tile degrades to 502 without it).
# Open http://wakapi.pcc.localhost → Settings, copy the API Key.
Plugins__Coding__ApiKey=

# Goodreads numeric user id (Reading tile degrades to 502 without it).
Plugins__Goodreads__UserId=

# Optional: override the committed dev-default CalDAV password (Calendar/Tasks).
# Plugins__Calendar__Password=
# Plugins__Tasks__Password=
