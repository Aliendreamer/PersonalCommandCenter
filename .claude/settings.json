{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(dotnet *)",
      "Bash(dotnet)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(docker *)",
      "Bash(openspec *)",
      "Bash(curl *)",
      "mcp__plugin_serena_serena__*"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git branch --delete --force*)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "network": {
      "allowedDomains": [
        "localhost",
        "127.0.0.1",
        "*.pcc.localhost",
        "registry.npmjs.org",
        "*.nuget.org",
        "github.com",
        "*.githubusercontent.com",
        "ghcr.io",
        "quay.io",
        "*.docker.io"
      ],
      "allowAllUnixSockets": true
    },
    "filesystem": {
      "allowWrite": [
        "/home/aliendreamer/projects/PersonalCommandCenter",
        "/tmp"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c 'if ((.tool_input.file_path // \"\") | test(\"apps/web/\")) then {hookSpecificOutput:{hookEventName:\"PreToolUse\",additionalContext:\"Frontend file under apps/web — before substantial frontend work, load the TanStack intent skills first: run `pnpm dlx @tanstack/intent@latest list`, then `pnpm dlx @tanstack/intent@latest load <package>#<skill>` and follow the returned SKILL.md (see AGENTS.md).\"}} else empty end'"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "dotnet-ai@dotnet-agent-skills": true,
    "dotnet-aspnet@dotnet-agent-skills": true,
    "dotnet@dotnet-agent-skills": true,
    "dotnet-data@dotnet-agent-skills": true,
    "dotnet-diag@dotnet-agent-skills": true,
    "dotnet-msbuild@dotnet-agent-skills": true,
    "dotnet-nuget@dotnet-agent-skills": true,
    "dotnet-template-engine@dotnet-agent-skills": true,
    "dotnet-test@dotnet-agent-skills": true,
    "dotnet-upgrade@dotnet-agent-skills": true
  },
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--open-web-dashboard",
        "false"
      ]
    }
  },
  "extraKnownMarketplaces": {
    "dotnet-agent-skills": {
      "source": {
        "source": "github",
        "repo": "dotnet/skills"
      }
    }
  }
}