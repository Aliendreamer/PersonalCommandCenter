{
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__plugin_serena_serena__read_file",
      "mcp__plugin_serena_serena__search_for_pattern",
      "mcp__plugin_serena_serena__activate_project",
      "mcp__plugin_serena_serena__find_symbol",
      "mcp__plugin_serena_serena__initial_instructions",
      "mcp__plugin_serena_serena__find_file",
      "mcp__plugin_serena_serena__get_symbols_overview",
      "mcp__plugin_serena_serena__list_dir",
      "mcp__plugin_serena_serena__get_current_config",
      "mcp__plugin_serena_serena__find_referencing_symbols",
      "mcp__plugin_serena_serena__find_implementations",
      "mcp__plugin_serena_serena__find_declaration",
      "mcp__plugin_serena_serena__list_memories",
      "mcp__plugin_serena_serena__read_memory"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git branch --delete --force*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c 'if ((.tool_input.file_path // \"\") | test(\"apps/web/\")) then {hookSpecificOutput:{hookEventName:\"PreToolUse\",additionalContext:\"Frontend file under apps/web — before substantial frontend work, load the TanStack intent skills first: run `pnpm dlx @tanstack/intent@latest list`, then `pnpm dlx @tanstack/intent@latest load <package>#<skill>` and follow the returned SKILL.md (see AGENTS.md).\"}} else empty end'"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "dotnet-ai@dotnet-agent-skills": true,
    "dotnet-aspnet@dotnet-agent-skills": true,
    "dotnet@dotnet-agent-skills": true,
    "dotnet-data@dotnet-agent-skills": true,
    "dotnet-diag@dotnet-agent-skills": true,
    "dotnet-msbuild@dotnet-agent-skills": true,
    "dotnet-nuget@dotnet-agent-skills": true,
    "dotnet-template-engine@dotnet-agent-skills": true,
    "dotnet-test@dotnet-agent-skills": true,
    "dotnet-upgrade@dotnet-agent-skills": true
  },
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--open-web-dashboard",
        "false"
      ]
    }
  },
  "extraKnownMarketplaces": {
    "dotnet-agent-skills": {
      "source": {
        "source": "github",
        "repo": "dotnet/skills"
      }
    }
  }
}
