root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{cs,csproj,props,targets}]
indent_size = 4

[*.cs]
# Treat analyzer/style issues consistently with warnings-as-errors builds
dotnet_analyzer_diagnostic.severity = warning

[*.md]
trim_trailing_whitespace = false
