{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Plugins": {
    "System": {
      "Enabled": true
    },
    "Iot": {
      "Enabled": true,
      "HomeAssistant": {
        "BaseUrl": "http://localhost:8123",
        "Token": ""
      },
      "Domains": ["light", "switch", "sensor", "binary_sensor"]
    }
  }
}
